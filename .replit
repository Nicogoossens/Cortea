modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Culture Protocols PT Translator"

[[workflows.workflow]]
name = "Culture Protocols PT Translator"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node scripts/run-all-culture-translations.mjs"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3003

[[ports]]
localPort = 8083
externalPort = 3001

[[ports]]
localPort = 8084
externalPort = 5000

[[ports]]
localPort = 8085
externalPort = 6000

[[ports]]
localPort = 21140
externalPort = 3000

[[ports]]
localPort = 21141
externalPort = 3002

[[ports]]
localPort = 21142
externalPort = 4200

[[ports]]
localPort = 21143
externalPort = 5173

[[ports]]
localPort = 21144
externalPort = 6800

[nix]
channel = "stable-25_05"

[objectStorage]
defaultBucketID = "replit-objstore-311b79c7-9f4b-42a0-9b23-3623379fc65e"

[userenv]

[userenv.shared]
CLOSED_BETA = "true"
BETA_INVITE_CODE = "DEV-BDA41371471CA2C7"

[userenv.production]
APP_PUBLIC_URL = "https://sowiso-01.replit.app"

[userenv.development]
ENABLE_TEST_DEBUG_ROUTES = "true"
