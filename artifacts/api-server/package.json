{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/kill-port.mjs && NODE_ENV=development tsx watch src/index.ts",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "auto-tag-questions": "tsx src/scripts/auto-tag-questions.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@replit/connectors-sdk": "^0.4.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-rate-limit": "^8.4.0",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.1",
    "jsonrepair": "^3.13.3",
    "nodemailer": "^8.0.5",
    "openid-client": "^6.8.3",
    "pino": "^9",
    "pino-http": "^10",
    "stripe": "^22.0.1",
    "stripe-replit-sync": "^1.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "catalog:",
    "@types/nodemailer": "^8.0.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:",
    "vitest": "^4.1.5"
  }
}
